<resources>
    <!-- Light Theme -->
    <style name="AppTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorPrimary">#2563EB</item>
        <item name="android:colorPrimaryDark">#1D4ED8</item>
        <item name="android:colorAccent">#3B82F6</item>
        <item name="android:windowBackground">#F8FAFC</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Dark Theme -->
    <style name="AppTheme.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorPrimary">#3B82F6</item>
        <item name="android:colorPrimaryDark">#1E3A5F</item>
        <item name="android:colorAccent">#60A5FA</item>
        <item name="android:windowBackground">#0F172A</item>
        <item name="android:statusBarColor">#0F172A</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#0F172A</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
